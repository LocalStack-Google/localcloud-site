---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const {
  title,
  description = 'LocalCloud — Google Cloud Platform in a box. Run major Google Cloud services locally in a single Docker container.',
  ogImage = `${base}brand/localcloud-social-card.svg`,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href={`${base}brand/localcloud-mark.svg`} type="image/svg+xml" />
    <meta name="theme-color" content="#eaf2ff" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Fonts: IBM Plex Sans (display/body) + IBM Plex Mono (code) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!-- PostHog Analytics -->
    <script is:inline>
      !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture register register_once register_for_session unregister opt_out_capturing has_opted_out_capturing opt_in_capturing reset isFeatureEnabled getFeatureFlag getFeatureFlagPayload reloadFeatureFlags group identify setPersonProperties setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags resetGroups onFeatureFlags addFeatureFlagsHandler onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey getNextSurveyStep".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);

      posthog.init('phc_o9nQDAQjEgsPcamE8pCnhv7ekA8CmA2VQXechLju9LA9', {
        api_host: 'https://us.i.posthog.com',
        // Pin default behaviors to this date to prevent upstream changes
        defaults: '2026-01-30',

        // Page tracking
        capture_pageview: true,
        capture_pageleave: 'if_capture_pageview',

        // Autocapture: clicks, form submissions, input changes
        autocapture: true,

        // Session replay — full DOM snapshots + mouse movement
        session_recording: {
          recordCrossOriginIframes: true,
        },

        // Error tracking
        capture_exceptions: true,

        // Capture heatmap data (clicks + rage clicks)
        capture_heatmaps: true,

        // UTM params, referrer, etc. persisted across pages
        store_google: true,
        save_referrer: true,

        // Anonymous events without creating person profiles (controls billing)
        person_profiles: 'identified_only',

        // Dead clicks detection
        capture_dead_clicks: true,

        // Web vitals + network timing
        capture_performance: {
          network_timing: true,
          web_vitals: true,
          web_vitals_allowed_metrics: ['CLS', 'FCP', 'FID', 'INP', 'LCP', 'TTFB'],
        },
      });
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />

    <script>
      // Enable reveal animations only when JS is available
      document.documentElement.classList.add('reveal-ready');
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.06, rootMargin: '0px 0px -30px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>

    <!-- PostHog custom event tracking -->
    <script is:inline>
      (function() {
        if (typeof window.posthog === 'undefined') return;

        // ─── Scroll depth tracking ───
        var scrollThresholds = [25, 50, 75, 90, 100];
        var scrollFired = new Set();

        function getScrollPercent() {
          var h = document.documentElement;
          var b = document.body;
          var scrollTop = h.scrollTop || b.scrollTop;
          var scrollHeight = (h.scrollHeight || b.scrollHeight) - h.clientHeight;
          return scrollHeight > 0 ? Math.round((scrollTop / scrollHeight) * 100) : 0;
        }

        var scrollTicking = false;
        window.addEventListener('scroll', function() {
          if (!scrollTicking) {
            requestAnimationFrame(function() {
              var pct = getScrollPercent();
              scrollThresholds.forEach(function(threshold) {
                if (pct >= threshold && !scrollFired.has(threshold)) {
                  scrollFired.add(threshold);
                  posthog.capture('scroll_depth', {
                    depth_percent: threshold,
                    page_path: window.location.pathname,
                    page_title: document.title,
                  });
                }
              });
              scrollTicking = false;
            });
            scrollTicking = true;
          }
        }, { passive: true });

        // ─── Single delegated click handler for all custom events ───
        document.addEventListener('click', function(e) {
          // Outbound links + CTA tracking
          var link = e.target.closest('a[href]');
          if (link) {
            var href = link.getAttribute('href');
            if (href) {
              if (href.startsWith('http') && !href.includes(window.location.hostname)) {
                posthog.capture('outbound_link_click', {
                  url: href,
                  link_text: (link.textContent || '').trim().slice(0, 100),
                  page_path: window.location.pathname,
                });
              }
              if (link.classList.contains('cta') ||
                  link.classList.contains('site-cta') ||
                  link.getAttribute('data-track') === 'cta') {
                posthog.capture('cta_click', {
                  cta_text: (link.textContent || '').trim().slice(0, 100),
                  cta_href: href,
                  page_path: window.location.pathname,
                  page_section: link.closest('section')?.className || 'unknown',
                });
              }
            }
          }

          // Code block copy buttons (scoped to avoid carousel false positives)
          if (e.target.closest('.docs-code-copy, .copy-button')) {
            posthog.capture('code_copied', {
              page_path: window.location.pathname,
              page_title: document.title,
            });
          }

          // Doc sidebar navigation
          var sidebarLink = e.target.closest('.docs-sidebar__link');
          if (sidebarLink) {
            posthog.capture('docs_nav_click', {
              target_page: sidebarLink.getAttribute('href'),
              link_label: (sidebarLink.textContent || '').trim(),
              from_page: window.location.pathname,
            });
          }

          // TOC link clicks
          var tocLink = e.target.closest('.docs-toc__link');
          if (tocLink) {
            posthog.capture('toc_click', {
              anchor: tocLink.getAttribute('href'),
              heading_text: (tocLink.textContent || '').trim(),
              page_path: window.location.pathname,
            });
          }
        });

        // ─── Time on page (active tab only, auto-clears) ───
        var pageStart = Date.now();
        var timeBuckets = [10, 30, 60, 120, 300];
        var timeFired = new Set();

        var timeInterval = setInterval(function() {
          if (document.hidden) return;
          var elapsed = Math.floor((Date.now() - pageStart) / 1000);
          timeBuckets.forEach(function(bucket) {
            if (elapsed >= bucket && !timeFired.has(bucket)) {
              timeFired.add(bucket);
              posthog.capture('time_on_page', {
                seconds: bucket,
                page_path: window.location.pathname,
                page_title: document.title,
              });
            }
          });
          if (timeFired.size >= timeBuckets.length) {
            clearInterval(timeInterval);
          }
        }, 5000);

        // ─── Persistent page metadata ───
        posthog.register_once({
          site: 'localcloud-docs',
          site_version: '1.0',
          landing_page: window.location.pathname,
          landing_referrer: document.referrer || 'direct',
        });
      })();
    </script>
  </body>
</html>
